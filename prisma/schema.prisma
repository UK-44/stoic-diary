// Stoic Diary - データモデル
// 仕様: docs/spec/02-domain-model.md

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  // Prisma 7: 接続 URL は prisma.config.ts の datasource / 実行時は PrismaClient の adapter で指定
  provider = "postgresql"
}

enum ComponentType {
  FIXED_MESSAGE
  RICH_TEXT // Notion 風リッチテキスト（HTML 保存）
  LABELED_TEXT // ラベルに 1:1 で紐づくリッチテキスト群（例: Good/Bad）
}

enum PeriodType {
  WEEK
  MONTH
}

model User {
  id           String          @id // Supabase Auth のユーザー UUID を採用（自動採番しない）
  email        String          @unique
  name         String?
  image        String?
  longTermGoal     String? // 日々の目標とは別の、長期目標（プロフィール的設定）
  longTermGoalDate DateTime? @db.Date // 長期目標の対象日（任意）
  components       DiaryComponent[]
  entries       DiaryEntry[]
  periodReviews PeriodReview[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
}

model PeriodReview {
  id          String     @id @default(cuid())
  userId      String
  periodType  PeriodType
  periodStart DateTime   @db.Date // 週=日曜始まり / 月=1日
  content     String?
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([userId, periodType, periodStart])
  @@index([userId, periodType, periodStart])
}

model DiaryComponent {
  id         String            @id @default(cuid())
  userId     String
  key        String // ユーザーごとに自動採番（手入力しない）
  name       String
  type       ComponentType
  config     Json              @default("{}")
  order      Int               @default(0) // ユーザーが自由に並び替えできる表示順
  archivedAt DateTime?
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  values     DiaryEntryValue[]
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@unique([userId, key])
  @@index([userId, order])
}

model DiaryEntry {
  id        String            @id @default(cuid())
  userId    String
  date      DateTime          @db.Date
  rating    Int?
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  values    DiaryEntryValue[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@unique([userId, date])
  @@index([userId, date])
}

model DiaryEntryValue {
  id          String         @id @default(cuid())
  entryId     String
  componentId String
  value       Json
  entry       DiaryEntry     @relation(fields: [entryId], references: [id], onDelete: Cascade)
  component   DiaryComponent @relation(fields: [componentId], references: [id], onDelete: Cascade)

  @@unique([entryId, componentId])
}
